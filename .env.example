# ─────────────────────────────────────────────────────────────────────────────
#  ZC OCW Environment Variables
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Enable: YouTube Data API v3
VITE_YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_V3_KEY

# Your university YouTube channel ID (starts with UC...)
# Find: channel page → About → Share → Copy channel ID
VITE_YOUTUBE_CHANNEL_ID=UCGNOEBp7AZaY4XPNoagpv8w

# ── Admin panel ───────────────────────────────────────────────────────────────
# Change this to a strong password before deploying
VITE_ADMIN_PASSWORD=change_me_to_something_strong

# ── Supabase (optional — enables cloud storage + file uploads) ────────────────
# 1. Create free project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL editor
# 3. Create a storage bucket named "materials" (public)
# 4. Get keys from: Project Settings → API

# Project URL (e.g. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=

# Anon/public key — safe to expose in frontend (read-only access)
VITE_SUPABASE_ANON_KEY=

# Service role key — KEEP SECRET, used only for admin writes
# In Vercel: add to environment variables but DO NOT prefix with VITE_
# In local .env only (never expose in browser)
VITE_SUPABASE_SERVICE_KEY=

# ── Site metadata ─────────────────────────────────────────────────────────────
VITE_SITE_NAME=ZC OCW
VITE_SITE_URL=https://ocw.zewailcity.edu.eg

VITE_WORKER_URL=https://zc-ocw-api.zc-ocw.workers.dev
