# ─────────────────────────────────────────────
#  ZC-OCW Environment Variables
#  Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# YouTube Data API v3
# Get it at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: "YouTube Data API v3" for the project
VITE_YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_V3_KEY

# Your university's YouTube Channel ID
# Find it: go to your channel → About → Share → Copy channel ID
# Format: UC... (starts with UC)
VITE_YOUTUBE_CHANNEL_ID=YOUR_CHANNEL_ID

# (Optional) If all course playlists live under one handle, set it here for display only
VITE_YOUTUBE_CHANNEL_HANDLE=@ZewailCityOCW

# Site metadata
VITE_SITE_NAME=ZC OCW
VITE_SITE_URL=https://ocw.zewailcity.edu.eg
